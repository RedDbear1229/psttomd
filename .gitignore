__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# uv — .venv 는 제외, uv.lock 은 재현 가능 빌드를 위해 커밋 대상
.venv/

# 아카이브 데이터 (별도 위치에 관리)
mail-archive/
*.pst
# 테스트 픽스처 PST 는 예외 — 다른 기기에서 테스트 실행에 필요
!tests/data/*.pst
# 단, 대용량 외부 코퍼스(예: Enron)는 별도 관리 (라이선스/프라이버시/사이즈)
tests/data/enron.pst

# 인덱스/상태
*.sqlite
*.sqlite-wal
*.sqlite-shm
.state.json
errors/

# pytest --basetemp 임시 디렉터리 (외부 리뷰·디버깅용)
.tmp_*/

# OS
.DS_Store
Thumbs.db

# Claude Code 임시 파일
$HOME/
.claude/
